{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@main/*": ["src/main/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "checkJs": true
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "out", ".vite"]
}
