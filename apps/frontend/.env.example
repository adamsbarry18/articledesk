# =============================================================================
# Configuration Electron + ApiArticle
# Copiez ce fichier vers .env et adaptez les valeurs.
# =============================================================================

NODE_ENV=development

# Serveur Vite du renderer (géré automatiquement par Electron Forge en dev)
MAIN_WINDOW_VITE_DEV_SERVER_URL=http://localhost:5173
MAIN_WINDOW_VITE_NAME=main_window

# Titre affiché dans l'application (accessible via import.meta.env.VITE_APP_TITLE)
VITE_APP_TITLE=Gestion Articles

# -----------------------------------------------------------------------------
# API ApiArticle — https://github.com/Chocolaterie/ApiArticle
# Démarrer l'API : git clone + npm install + npm start (port 3000 par défaut)
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:3000

# Token GitHub pour npm run publish (ne jamais committer)
# GITHUB_TOKEN=ghp_xxxxxxxx
